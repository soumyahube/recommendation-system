{
  "servers": {
    "PubNub": {
      "command": "npx",
      "args": ["-y", "@pubnub/mcp@latest"],
      "env": {
        "PUBNUB_API_KEY": "${input:pubnub-api-key}",
        "PUBNUB_PUBLISH_KEY": "${input:PUBNUB_PUBLISH_KEY}",
        "PUBNUB_SUBSCRIBE_KEY": "${input:PUBNUB_SUBSCRIBE_KEY}"
      },
      "type": "stdio"
    },
    "io.github.github/github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "gallery": "https://api.mcp.github.com",
      "version": "1.0.0"
    }
  },
  "inputs": [
    {
      "id": "pubnub-api-key",
      "type": "promptString",
      "description": "PubNub API Key",
      "password": true
    },
    {
      "id": "PUBNUB_PUBLISH_KEY",
      "type": "promptString",
      "description": "Optional PubNub publish key for real-time operations",
      "password": true
    },
    {
      "id": "PUBNUB_SUBSCRIBE_KEY",
      "type": "promptString",
      "description": "Optional PubNub subscribe key for real-time operations",
      "password": true
    },
    {
      "id": "PUBNUB_USER_ID",
      "type": "promptString",
      "description": "Optional User ID for SDK operations (default: pubnub-mcp)",
      "password": false
    }
  ]
}